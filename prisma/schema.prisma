// ---------- CONFIG ----------
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
enum LostPetStatus {
  lost
  found
  pending
  closed
  reunited
  reported
  fake
}



generator client {
  provider = "prisma-client-js"
}

// ---------- PET SPECIES ----------
model PetSpecies {
  id        Int       @id @default(autoincrement())
  name      String    @unique // เช่น "Cat", "Dog", "Rabbit"
  pets      Pet[]
  foundPets FoundPet[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ---------- USER / AUTH ----------
model User {
  id            String          @id @default(cuid())
  name          String?
  firstName     String?
  lastName      String?
  email         String?         @unique
  password      String?
  phone         String?
  image         String?
  role          String?         @default("user")
  houseNumber   String?
  street        String?
  village       String?
  subDistrict   String?
  district      String?
  province      String?
  emailVerified DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  pets          Pet[]
  lostPets      LostPet[]
  clues         Clue[]
  foundPets     FoundPet[]
  notifications Notification[]
  passwordResetTokens PasswordResetToken[]
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String  @unique
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User?   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  @@unique([identifier, token])
}

// ---------- PET PROFILE ----------
model LostPet {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  location    String
  lat         Float?
  lng         Float?
  lostDate    DateTime
  reward      Float?
  status      LostPetStatus @default(lost)
  userId      String
  user        User         @relation(fields: [userId], references: [id])

  // 🔗 เชื่อมกับ Pet แบบบังคับ
  petId       Int
  pet         Pet          @relation(fields: [petId], references: [id])

  images      LostPetImage[]
  clues       Clue[]
  createdAt   DateTime     @default(now())
}


model PetChronicDisease {
  id          Int      @id @default(autoincrement())
  petId       Int
  disease     String   // ชื่อโรค เช่น "โรคไต", "โรคหัวใจ"
  description String?  // รายละเอียดเพิ่มเติม
  diagnosedAt DateTime? // วันที่วินิจฉัย
  pet         Pet      @relation(fields: [petId], references: [id])
}

model VaccineRecord {
  id         Int      @id @default(autoincrement())
  petId      Int
  vaccine    String   // ชื่อวัคซีน เช่น "วัคซีนพิษสุนัขบ้า"
  date       DateTime // วันที่ฉีด
  nextDue    DateTime? // วันครบกำหนดครั้งถัดไป
  note       String?
  pet        Pet      @relation(fields: [petId], references: [id])
}
model Pet {
  id              Int               @id @default(autoincrement())
  name            String
  speciesId       Int
  species         PetSpecies        @relation(fields: [speciesId], references: [id])
  breed           String?
  gender          String?
  age             Int?
  color           Json?
  description     String?
  userId          String
  markings        String?
  isNeutered      Int
  user            User              @relation(fields: [userId], references: [id])
  images          PetImage[]
  chronicDiseases PetChronicDisease[]
  vaccines        VaccineRecord[]
  lostPets        LostPet[]
  createdAt       DateTime          @default(now())
}

model PetImage {
  id      Int    @id @default(autoincrement())
  url     String // URL ของภาพ
  petId   Int    // petId ของสัตว์เลี้ยง
  pet     Pet    @relation(fields: [petId], references: [id])
}



model LostPetImage {
  id        Int      @id @default(autoincrement())
  url       String   // URL ของภาพ
  lostPetId Int      // lostPetId
  lostPet   LostPet  @relation(fields: [lostPetId], references: [id])
}

model Clue {
  id         Int        @id @default(autoincrement())
  content    String     // ข้อความที่ให้เบาะแส
  location   String?    // สถานที่ที่พบเบาะแส
  lat        Float?     // ละติจูด
  lng        Float?     // ลองจิจูด
  userId     String     // userId ของผู้ให้เบาะแส
  lostPetId  Int        // lostPetId
  user       User       @relation(fields: [userId], references: [id])
  lostPet    LostPet    @relation(fields: [lostPetId], references: [id])
  images     ClueImage[]
  createdAt  DateTime   @default(now())
}

model ClueImage {
  id      Int    @id @default(autoincrement())
  url     String // URL ของภาพ
  clueId  Int    // clueId
  clue    Clue   @relation(fields: [clueId], references: [id])
}

// ---------- FOUND PET (หาเจ้าของ) ----------
model FoundPet {
  id          Int            @id @default(autoincrement())
  title       String
  description String
  location    String
  lat         Float?
  lng         Float?
  foundDate   DateTime

  speciesId   Int
  species     PetSpecies     @relation(fields: [speciesId], references: [id])
  breed       String?
  gender      String?
  color       Json?
  age         Int?
  distinctive String?
  status      String         @default("finding")
  images      FoundPetImage[]
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model FoundPetImage {
  id         Int       @id @default(autoincrement())
  url        String    // URL ของภาพ
  foundPetId Int
  foundPet   FoundPet  @relation(fields: [foundPetId], references: [id])
}
model Notification {
  id          Int      @id @default(autoincrement())
  userId      String   // ผู้รับการแจ้งเตือน
  user        User     @relation(fields: [userId], references: [id])
  
  title       String   // หัวข้อการแจ้งเตือน
  message     String   // ข้อความ
  type        String   // ประเภท: "new_clue", "pet_found", "new_message"
  
  // ลิงก์ที่จะไปเมื่อกดการแจ้งเตือน
  linkUrl     String?  // เช่น "/lost-pets/123", "/found-pets/456"
  
  // ข้อมูลอ้างอิง (เก็บ ID ของข้อมูลที่เกี่ยวข้อง)
  referenceId Int?     // เช่น lostPetId, foundPetId, clueId
  referenceType String? // เช่น "lost_pet", "found_pet", "clue"
  
  // สถานะ
  isRead      Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}