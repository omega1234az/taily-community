// ---------- CONFIG ----------
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------- USER / AUTH ----------
model User {
  id            String          @id @default(cuid())
  name          String?
  firstName     String?         // เพิ่มชื่อจริง
  lastName      String?         // เพิ่มนามสกุล
  email         String?         @unique
  password      String?
  phone         String?         // เพิ่มเบอร์โทร
  image         String?
  role          String?         @default("user")

  houseNumber   String?         // เพิ่มที่อยู่
  street        String?
  village       String?
  subDistrict   String?
  district      String?
  province      String?

  emailVerified DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  accounts      Account[]
  pets          Pet[]
  lostPets      LostPet[]
  clues         Clue[]
  foundPets     FoundPet[]      // เปลี่ยนจาก adoptions เป็น foundPets
  passwordResetTokens PasswordResetToken[]
}


model Account {
  id                       String  @id @default(cuid())
  userId                   String  @unique
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}


model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}



// ---------- PET PROFILE ----------
model Pet {
  id          Int        @id @default(autoincrement())
  name        String   // ชื่อสัตว์เลี้ยง
  species     String     // เช่น "dog", "cat"
  breed       String? // เช่น "Labrador", "Siamese"
  gender      String? // เพศ เช่น
  age         Int? //อายุ
  color       String? //สี
  description String?   // รายละเอียด เช่น "ชอบเล่น", "ขี้อ้อน"
  userId      String // userId ของเจ้าของสัตว์เลี้ยง
  markings   String?  // ลักษณะเฉพาะ เช่น "white with black spots"
  isNeutered  Int  //ทำหมันหรือไม่ 0 = ไม่ทำหมัน, 1 = ทำหมัน
  user        User       @relation(fields: [userId], references: [id])
  images      PetImage[]

  createdAt   DateTime   @default(now())
}

model PetImage {
  id      Int    @id @default(autoincrement())
  url     String  // URL ของภาพ
  petId   Int  // petId ของสัตว์เลี้ยง
  pet     Pet    @relation(fields: [petId], references: [id])
}



// ---------- LOST PET ----------
model LostPet {
  id          Int          @id @default(autoincrement())
  title       String // ชื่อสัตว์ที่หาย
  description String // รายละเอียด เช่น "หายที่ไหน", "ลักษณะเฉพาะ"
  location    String // สถานที่หาย เช่น "บ้านเลขที่ 123 ถนน ABC"
  lat         Float? // ละติจูด
  lng         Float? // ลองจิจูด
  lostDate    DateTime  // วันที่หาย
  petType     String  // ประเภทสัตว์ เช่น "dog", "cat"
  reward      Float? // รางวัล เช่น 100.00
  userId      String // userId ของเจ้าของสัตว์ที่หาย
  user        User         @relation(fields: [userId], references: [id])
  images      LostPetImage[]
  clues       Clue[]
  createdAt   DateTime     @default(now())
}

model LostPetImage {
  id        Int      @id @default(autoincrement())
  url       String // URL ของภาพ
  lostPetId Int // lostPetId ของสัตว์ที่หาย
  lostPet   LostPet  @relation(fields: [lostPetId], references: [id])
}

model Clue {
  id         Int        @id @default(autoincrement())
  content    String // ข้อความที่ให้เบาะแส เช่น "เห็นที่บ้านเลขที่ 123"
  location   String? // สถานที่ที่พบเบาะแส เช่น "บ้านเลขที่ 123 ถนน ABC"
  lat        Float? // ละติจูด
  lng        Float? // ลองจิจูด
  userId     String // userId ของผู้ให้เบาะแส
  lostPetId  Int // lostPetId ของสัตว์ที่หาย
  user       User       @relation(fields: [userId], references: [id])
  lostPet    LostPet    @relation(fields: [lostPetId], references: [id])
  images     ClueImage[]
  createdAt  DateTime   @default(now())
}

model ClueImage {
  id      Int    @id @default(autoincrement())
  url     String // URL ของภาพ
  clueId  Int // clueId ของเบาะแส
  clue    Clue   @relation(fields: [clueId], references: [id])
}

// ---------- FOUND PET (หาเจ้าของ) ----------
model FoundPet {
  id          Int            @id @default(autoincrement())
  title       String // ชื่อสัตว์ที่พบ
  description String // รายละเอียด เช่น "ลักษณะเฉพาะ"
  location    String // สถานที่พบ เช่น "บ้านเลขที่ 123 ถนน ABC"
  lat         Float? // ละติจูด
  lng         Float?
  foundDate   DateTime// วันที่พบสัตว์
  species     String  // ประเภทสัตว์
  breed       String? // เช่น "Labrador", "Siamese"
  gender      String? // เพศ เช่น
  color       String? // สี
  age         Int?           // อายุโดยประมาณ
  distinctive String?        // ลักษณะเด่น
  status      String         @default("finding") // สถานะ: finding - กำลังหาเจ้าของ, returned - คืนเจ้าของเเล้ว
  images      FoundPetImage[]
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model FoundPetImage {
  id         Int       @id @default(autoincrement())
  url        String // URL ของภาพ
  foundPetId Int
  foundPet   FoundPet  @relation(fields: [foundPetId], references: [id])
}